{
  "name": "learncardano-leaderboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:studio": "drizzle-kit studio",
    "seed:test:local": "wrangler d1 execute DB --local --file=scripts/seed-test-data.sql",
    "seed:test:remote": "wrangler d1 execute DB --remote --file=scripts/seed-test-data.sql",
    "clean:test:local": "wrangler d1 execute DB --local --file=scripts/clean-test-data.sql",
    "clean:test:remote": "wrangler d1 execute DB --remote --file=scripts/clean-test-data.sql"
  },
  "dependencies": {
    "@cardano-foundation/cardano-connect-with-wallet": "^0.2.20",
    "@cardano-foundation/cardano-connect-with-wallet-core": "^0.2.11",
    "@cardano-foundation/cardano-verify-datasignature": "^1.0.11",
    "@noble/hashes": "^2.2.0",
    "@opennextjs/cloudflare": "^1.19.8",
    "bech32": "^2.0.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260510.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}

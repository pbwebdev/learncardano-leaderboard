# learncardano-leaderboard — local environment template
# Copy this to .env.local (gitignored) and fill in. Wrangler also reads
# .dev.vars for `wrangler dev` (gitignored).
#
# Worker secrets in prod are set via `wrangler secret put <NAME>`. Build-time
# env that Next bakes into the bundle must be in .env.local for
# `npx opennextjs-cloudflare build` to see it (notably
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY — see GOTCHAS.md §3).

# --- Phase 0 scaffold (already in .env.local / .dev.vars / Worker secrets) ---
AUTH_SESSION_SECRET=
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# --- Cardano providers ---
BLOCKFROST_PROJECT_ID=

# --- Admin allow-list — comma-separated bech32 stake addresses ---
ADMIN_STAKE_ADDRESSES=
OWNER_STAKE_ADDRESS=

# ============================================================================
# Phase 3 secrets (set before lighting up the corresponding feature)
# ============================================================================

# --- Dub.co link tracking ---
# Sign up at https://dub.co, create a workspace, then:
#   1. Settings → API Keys → Create API key (workspace scope)
#   2. Settings → Webhooks → Create endpoint pointing at
#      https://leaderboard.learncardano.io/api/webhooks/dub
#      Select the `link.clicked` event. Copy the signing secret.
DUB_API_KEY=
DUB_WEBHOOK_SECRET=

# --- X (Twitter) OAuth 2.0 ---
# https://developer.x.com → Projects & Apps → Create an OAuth 2.0 app.
# Required settings:
#   App type:           Web app (confidential client)
#   Callback URL:       https://leaderboard.learncardano.io/api/oauth/x/callback
#   Scopes:             tweet.read, users.read, offline.access
# Then copy the Client ID + Client Secret into the values below. Wrangler:
#   wrangler secret put X_CLIENT_ID
#   wrangler secret put X_CLIENT_SECRET
X_CLIENT_ID=
X_CLIENT_SECRET=

# --- Google / YouTube OAuth ---
# https://console.cloud.google.com → APIs & Services → Credentials →
# Create credentials → OAuth client ID. Required settings:
#   App type:           Web application
#   Authorized redirect URIs:
#     https://leaderboard.learncardano.io/api/oauth/youtube/callback
# Then enable the YouTube Data API v3 under APIs & Services → Library.
# Note the OAuth consent screen must be in "Production" or have your test
# users added, else the flow returns access_denied.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Learn Cardano Bounty webhook HMAC (Phase 4) ---
BOUNTY_WEBHOOK_HMAC_SECRET=
